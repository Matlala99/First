<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/feedFragment">

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.firstword.app.ui.feed.FeedFragment"
        android:label="@string/nav_feed"
        tools:layout="@layout/fragment_feed" />

    <fragment
        android:id="@+id/mapFragment"
        android:name="com.firstword.app.ui.map.MapFragment"
        android:label="@string/nav_map"
        tools:layout="@layout/fragment_map" />

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.firstword.app.ui.search.SearchFragment"
        android:label="@string/nav_search"
        tools:layout="@layout/fragment_search" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.firstword.app.ui.profile.ProfileFragment"
        android:label="@string/nav_profile"
        tools:layout="@layout/fragment_profile" />
    <!-- Add to your nav_graph.xml -->
    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.firstword.app.ui.create.CreatePostFragment"
        android:label="Create Post"
        tools:layout="@layout/fragment_create_post" />

    <!-- Add actions from feed fragment -->
    <action
        android:id="@+id/action_feedFragment_to_createPostFragment"
        app:destination="@id/createPostFragment" />
    <fragment
        android:id="@+id/feedFragment"
        android:name="com.firstword.app.ui.feed.FeedFragment"
        android:label="Feed"
        tools:layout="@layout/fragment_feed" />



    <fragment
        android:id="@+id/createPostFragment"
        android:name="com.firstword.app.ui.create.CreatePostFragment"
        android:label="Create Post"
        tools:layout="@layout/fragment_create_post" />

</navigation>
