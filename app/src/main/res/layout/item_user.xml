<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/image_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_profile"
            android:background="@drawable/circle_background" />

        <!-- Verified Badge -->
        <ImageView
            android:id="@+id/image_verified"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignTop="@id/image_avatar"
            android:layout_alignEnd="@id/image_avatar"
            android:src="@drawable/ic_verified"
            android:visibility="gone" />

        <!-- User Info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/image_avatar"
            android:layout_alignTop="@id/image_avatar"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_display_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/text_handle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@johndoe"
                android:textSize="14sp"
                android:textColor="@color/gray_600"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Follow Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_follow"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignTop="@id/image_avatar"
            android:layout_alignParentEnd="true"
            android:text="Follow"
            android:textSize="14sp"
            app:cornerRadius="18dp" />

        <!-- Bio -->
        <TextView
            android:id="@+id/text_bio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/image_avatar"
            android:layout_marginTop="8dp"
            android:text="This is a sample bio that describes the user."
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Stats -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_bio"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_followers_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.2k"
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" followers · "
                android:textSize="13sp"
                android:textColor="@color/gray_600" />

            <TextView
                android:id="@+id/text_following_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="345"
                android:textSize="13sp"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" following"
                android:textSize="13sp"
                android:textColor="@color/gray_600" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>